{
  "name": "@react-three/start",
  "version": "0.0.0",
  "description": "A meta-framework for boilerplate-free React Three Fiber apps using file-based scene composition.",
  "license": "MIT",
  "access": "public",
  "type": "module",
  "homepage": "https://github.com/pmndrs/react-three-start",
  "author": "Bela Bohlender",
  "sideEffects": false,
  "main": "src/runtime.tsx",
  "bin": {
    "start": "./dist/cli.js",
    "react-three-start": "./dist/cli.js",
    "r3s": "./dist/cli.js"
  },
  "files": [
    "README.md",
    "dist",
    "logo.png"
  ],
  "publishConfig": {
    "main": "dist/runtime.js"
  },
  "keywords": [
    "react",
    "three",
    "threejs",
    "react-three-fiber",
    "r3f",
    "vite",
    "webgl",
    "webxr"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pmndrs/react-three-start"
  },
  "scripts": {
    "build": "tsup src/runtime.tsx src/plugin.ts --format esm --dts --clean && tsup src/cli.ts --format esm --no-dts",
    "prepack": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@react-three/fiber": ">=9",
    "react": ">=19",
    "react-dom": ">=19",
    "three": ">=0.175.0"
  },
  "devDependencies": {
    "@react-three/fiber": "^9.1.2",
    "@types/fs-extra": "^11.0.4",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/three": "^0.176.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.176.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "@babel/parser": "^7.29.3",
    "@immersive-web-editor/adapter": "^0.0.24",
    "@vitejs/plugin-react": "^4.7.0",
    "cac": "^7.0.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "magic-string": "^0.30.21",
    "open": "^11.0.0",
    "package-manager-detector": "^1.6.0",
    "picocolors": "^1.1.1",
    "vite": "^6.3.4"
  }
}
